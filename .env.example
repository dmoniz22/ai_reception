# ==========================================
# AI Receptionist — Environment Variables
# ==========================================

# Deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER_SID=

# Ollama Cloud
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_ENDPOINT=https://api.ollama.com/v1

# Server
HOST=0.0.0.0
PORT=8001

# Internal API key (for Deepgram function call endpoints)
INTERNAL_API_KEY=

# Database (Docker internal)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_reception

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=price_REPLACE_ME

# Domain
DOMAIN=reception.monizhealth.com

# Google OAuth (for Calendar scheduling)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://reception.monizhealth.com

# Frontend
NEXT_PUBLIC_API_URL=http://server:8001
